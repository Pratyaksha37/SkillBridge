generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String         @id @default(uuid())
  email          String         @unique
  password       String
  name           String
  bio            String?
  title          String?        // e.g. Senior Product Designer
  imageUrl       String?
  role           Role           @default(LEARNER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  userSkills     UserSkill[]
  sessionsAsTeacher Session[]   @relation("TeacherSessions")
  sessionsAsLearner Session[]   @relation("LearnerSessions")
  messagesSent      Message[]   @relation("MessagesSent")
  messagesReceived  Message[]   @relation("MessagesReceived")
  ratingsGiven      Rating[]    @relation("RatingsGiven")
  ratingsReceived   Rating[]    @relation("RatingsReceived")
}

model Skill {
  id          String      @id @default(uuid())
  name        String      @unique
  category    String
  userSkills  UserSkill[]
}

model UserSkill {
  id        String   @id @default(uuid())
  userId    String
  skillId   String
  type      SkillType 
  level     String?  // Beginner, Intermediate, Expert
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId, type])
  @@index([skillId])
  @@index([userId])
}

model Session {
  id           String        @id @default(uuid())
  teacherId    String
  learnerId    String
  skillId      String?
  status       SessionStatus @default(PENDING)
  scheduledAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  teacher      User     @relation("TeacherSessions", fields: [teacherId], references: [id], onDelete: Cascade)
  learner      User     @relation("LearnerSessions", fields: [learnerId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([learnerId])
}

model Message {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  content    String
  read       Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender     User     @relation("MessagesSent", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("MessagesReceived", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
}

model Rating {
  id          String   @id @default(uuid())
  reviewerId  String
  revieweeId  String
  score       Int      // 1 to 5
  comment     String?
  createdAt   DateTime @default(now())

  reviewer    User     @relation("RatingsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee    User     @relation("RatingsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)

  @@index([revieweeId])
}

enum Role {
  LEARNER
  TEACHER
  BOTH
}

enum SkillType {
  OFFER
  SEEK
}

enum SessionStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
}
