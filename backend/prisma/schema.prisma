generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  bio       String?
  about     String?
  location  String?
  availability String?
  languages String?
  createdAt DateTime @default(now())

  skills            UserSkill[]
  sessionsAsTeacher Session[]   @relation("TeacherSessions")
  sessionsAsLearner Session[]   @relation("LearnerSessions")
  messagesSent      Message[]
  ratingsGiven      Rating[]    @relation("RatingsGiven")
  ratingsReceived   Rating[]    @relation("RatingsReceived")
  connectionsMade   Connection[] @relation("Requester")
  connectionsRecv   Connection[] @relation("Receiver")
}

model Connection {
  id          String   @id @default(uuid())
  requesterId String
  receiverId  String
  createdAt   DateTime @default(now())

  requester User @relation("Requester", fields: [requesterId], references: [id])
  receiver  User @relation("Receiver", fields: [receiverId], references: [id])

  @@unique([requesterId, receiverId])
}

model Skill {
  id       String      @id @default(uuid())
  name     String      @unique
  category String
  users    UserSkill[]
  sessions Session[]
}

enum SkillType {
  OFFER
  SEEK
}

model UserSkill {
  id      String    @id @default(uuid())
  userId  String
  skillId String
  type    SkillType

  user  User  @relation(fields: [userId], references: [id])
  skill Skill @relation(fields: [skillId], references: [id])

  @@unique([userId, skillId, type])
}

enum SessionStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMPLETED
  CANCELLED
}

model Session {
  id          String        @id @default(uuid())
  teacherId   String
  learnerId   String
  skillId     String
  scheduledAt DateTime
  status      SessionStatus @default(PENDING)
  createdAt   DateTime      @default(now())

  teacher User      @relation("TeacherSessions", fields: [teacherId], references: [id])
  learner User      @relation("LearnerSessions", fields: [learnerId], references: [id])
  skill   Skill     @relation(fields: [skillId], references: [id])
  messages Message[]
}

model Message {
  id        String   @id @default(uuid())
  content   String
  senderId  String
  sessionId String
  createdAt DateTime @default(now())

  sender  User    @relation(fields: [senderId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])
}

model Rating {
  id          String   @id @default(uuid())
  score       Int
  feedback    String?
  raterId     String
  ratedUserId String
  createdAt   DateTime @default(now())

  rater     User @relation("RatingsGiven", fields: [raterId], references: [id])
  ratedUser User @relation("RatingsReceived", fields: [ratedUserId], references: [id])
}
